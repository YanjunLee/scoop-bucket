{
    "version": "104.0.1",
    "description": "Firefox 浏览器中文版本",
    "homepage": "https://www.mozilla.org/firefox/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/104.0.1/win64/zh-CN/Firefox%20Setup%20104.0.1.exe#/dl.7z",
            "hash": "sha512:340de609eb10e5c5be7abcd2ae23ec443e2c0f3de4e9d980158af59eebf7c058af1cc1517e08767fe2c8d8b52a3fa7a3031cd1cb6c130824948ae85d3692fd1a"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/104.0.1/win32/zh-CN/Firefox%20Setup%20104.0.1.exe#/dl.7z",
            "hash": "sha512:7067990b8f154ad57c158907e2c8439bbe8929664162b4a68462b148849389a8404742165d728eb3fe8d6e56307186a9fd6e51d534c2b1250be6dca1ffc0c765"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "firefox.exe",
            "firefox",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox",
            "-profile \"$dir\\profile\""
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://www.mozilla.org/en-US/firefox/notes/",
        "regex": "<div class=\"c-release-version\">([\\d.]+)</div>"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/zh-CN/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/zh-CN/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/zh-CN/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/zh-CN/$basename"
                }
            }
        }
    }
}
