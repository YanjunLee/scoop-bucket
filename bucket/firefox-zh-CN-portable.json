{
    "version": "94.0.2",
    "description": "Firefox 浏览器中文版本",
    "homepage": "https://www.mozilla.org/firefox/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/94.0.2/win64/zh-CN/Firefox%20Setup%2094.0.2.exe#/dl.7z",
            "hash": "sha512:7cc02e821e8d9fd4672e1cd3054f6f430a4a43a8edf2406f06f39fa755ac815f59cd8d8962e53b3d44c4f8028fad22b9a4ffcd666788a341b2f0dc1233729d68"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/94.0.2/win32/zh-CN/Firefox%20Setup%2094.0.2.exe#/dl.7z",
            "hash": "sha512:d0f9b4e068f971e2c1207dfb529612930d9920c6d6af777d5cf40bce2306d0cce9919875e95f3e73c83e494346c7ccdf58164b4bde1dd11b9d6b58403b7bdbcd"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "firefox.exe",
            "firefox",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox",
            "-profile \"$dir\\profile\""
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://www.mozilla.org/en-US/firefox/notes/",
        "regex": "<div class=\"c-release-version\">([\\d.]+)</div>"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/zh-CN/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/zh-CN/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/zh-CN/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/zh-CN/$basename"
                }
            }
        }
    }
}
