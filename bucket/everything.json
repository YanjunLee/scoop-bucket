    "architecture": {
        "64bit": {
            "url": "https://www.voidtools.com/Everything-1.4.1.1009.x64.zip",
            "hash": "f61b601acba59d61fb0631a654e48a564db34e279b6f2cc45e20a42ce9d9c466"
        },
        "32bit": {
            "url": "https://www.voidtools.com/Everything-1.4.1.1009.x86.zip",
            "hash": "3ada0479c4d55b185a33f7700d7ace8cd85cdceb8ddb610e062cfe04558275ca"
        }
    },
    "bin": "Everything.exe",
    "shortcuts": [
        [
            "Everything.exe",
            "Everything"
        ]
    ],
    "persist": [
        "Logs",
        "Everything.ini",
        "Bookmarks.csv",
        "Run History.csv",
        "Search History.csv"
    ],
    "pre_install": [
        "if (!(test-path \"$persist_dir\")) { mkdir \"$persist_dir\" }",
        "Add-Content \"$persist_dir\\Everything.ini\" $null;",
        "Add-Content \"$persist_dir\\Bookmarks.csv\" $null;",
        "Add-Content \"$persist_dir\\Run History.csv\" $null;",
        "Add-Content \"$persist_dir\\Search History.csv\" $null;"
    ],
    "checkver": "Download Everything ([\\d.]+)",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.voidtools.com/Everything-$version.x64.zip"
            },
            "32bit": {
                "url": "https://www.voidtools.com/Everything-$version.x86.zip"
            }
        },
        "hash": {
            "url": "$baseurl/Everything-$version.sha256"
        }
    }
}
